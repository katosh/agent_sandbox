#!/bin/bash --
# sandbox-notify — Send a notification from inside the sandbox.
#
# Usage: sandbox-notify [MESSAGE]
#
# Notifies the user by:
#   1. Ringing the terminal bell, which marks the window/tab in the
#      inner tmux status bar (via monitor-bell).
#   2. Asking the chaperon to ring the bell on the outer terminal,
#      which marks the sandbox's tab in the outer tmux.
#
# Used by agent hooks (Claude Code, etc.) and available to all agents
# on $PATH inside the sandbox.

msg="${*:-Agent notification}"

# 1. Inner tmux: ring the bell to mark the window/tab in the status bar.
#    This is more useful than display-message because tmux's monitor-bell
#    highlights which specific window needs attention.
printf '\a' 2>/dev/null

# 2. Outer tmux: relay via the chaperon (which runs outside the sandbox
#    and rings the bell on the outer terminal to mark the tab).
_BIN_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
_NOTIFY_STUB="$_BIN_DIR/../chaperon/stubs/notify"
if [[ -n "${_CHAPERON_FIFO_DIR:-}" && -f "$_NOTIFY_STUB" ]]; then
    "$_NOTIFY_STUB" "$msg" 2>/dev/null || true
fi

exit 0
