#!/bin/bash --
# lab — Project-local JupyterLab launcher, kernel manager, and notebook
# runner.  (Run `lab help` for full usage.)

set -eo pipefail

PROG="lab"
DIR="$PWD"
: "${JUPYTER_CONFIG_DIR:=$DIR/.jupyter}"
: "${JUPYTER_DATA_DIR:=$DIR/.jupyter/share/jupyter}"
KERNELS_DIR="$JUPYTER_DATA_DIR/kernels"
VENV_DIR="$DIR/.venv"
BG_PID_FILE="$JUPYTER_CONFIG_DIR/lab.bg.pid"
BG_LOG_FILE="$JUPYTER_CONFIG_DIR/lab.bg.log"

# Absolute path to the directory holding this script — so the Python helper
# (bin/_lab_kernel.py) can be located even when the user runs `lab` via a
# symlink or from $PATH.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HELPER_PY="$SCRIPT_DIR/_lab_kernel.py"

export JUPYTER_CONFIG_DIR JUPYTER_DATA_DIR

err() { echo "$PROG: $*" >&2; }
die() { err "$@"; exit 1; }

usage() {
    cat <<'HELP'
lab — Project-local JupyterLab launcher, kernel manager, and notebook runner.

Runs JupyterLab from the current directory with all configuration and
kernels under ./.jupyter, so each project gets its own reproducible Jupyter
setup with no writes to ~/.local. Also provides CLI access to running
kernels so code can be executed against a live notebook's state without
clicking through the web UI.

USAGE
  lab                          Start JupyterLab in the current directory
                               (foreground; typical when run in a tmux pane)
  lab start                    Start JupyterLab in the background, log to
                               ./.jupyter/lab.bg.log, return immediately
  lab stop                     Stop a background JupyterLab owning this project
  lab status                   List running lab servers and kernels
  lab password                 Set a persistent password (stored in ./.jupyter)
  lab help                     Show this help

  lab kernel add [NAME]        Create ./.venv and register it as a kernelspec
  lab kernel list              List registered kernelspecs in this project
  lab kernel remove NAME       Unregister a kernelspec

  lab kernel ps                List RUNNING kernels (PID, short id, notebook)
  lab kernel find QUERY        Show running kernel(s) matching a notebook path
  lab kernel exec [-n NB|-k K] CODE
                               Run CODE in a live kernel; state persists.
                               `-` or `-f FILE` reads from stdin/file.
  lab kernel inspect [-n NB|-k K] [PATTERN]
                               `whos`-style listing of live variables

  lab notebook attach [PATH]   Ensure a kernel is running for PATH (spawns
                               a session via the lab server if needed)
  lab notebook cells [-n PATH] List cells
  lab notebook show  [-n PATH] IDX
  lab notebook append  [-n PATH] [--markdown] [--execute] CODE
  lab notebook replace [-n PATH] IDX           [--execute] CODE

TWO RUN MODES
  1. Agent background mode
       lab start                      # agent daemonizes the server
       lab notebook attach foo.ipynb  # spawns a kernel
       lab kernel exec -n foo.ipynb "df = pd.read_csv('data.csv')"
       lab kernel exec -n foo.ipynb "df.shape"

  2. User foreground mode (tmux pane inside the sandbox)
       lab                            # bare `lab` runs in foreground
     Then in another pane, the agent uses the same `lab kernel exec -n ...`
     commands to attach to whatever notebook you have open in the browser.

SELECTORS
  `-n NOTEBOOK` resolves to a running kernel by matching the kernel's
  jupyter_session against: absolute path, PWD-relative path, basename
  (globbed under PWD), or substring. On ambiguous matches the command
  prints the candidates and exits non-zero — by design, it will not guess.

  `-k SELECTOR` accepts PID, short kernel id (first 8 hex), or full
  connection file path.

  With neither flag and exactly one running kernel, that kernel is used.

NETWORK & AUTH
  Default bind is 127.0.0.1 — safest on shared HPC. For laptop access,
  prefer an SSH tunnel (`ssh -L 8888:localhost:8888 user@host`).  To bind
  everywhere, use `IP=0.0.0.0 lab` (optionally with JUPYTER_CERTFILE and
  JUPYTER_KEYFILE for TLS).  Jupyter prints a token URL on start — copy
  that to authenticate a browser session, or set a persistent password
  with `lab password`.

ENVIRONMENT VARIABLES
  PORT, IP                     Defaults for --port / --ip
  JUPYTER_CERTFILE/KEYFILE     TLS cert / key (enables HTTPS if both set)
  JUPYTER_CONFIG_DIR           default: ./.jupyter
  JUPYTER_DATA_DIR             default: ./.jupyter/share/jupyter

REQUIREMENTS
  `uv` on PATH (used by lab to manage the project venv and run jupyter-lab).
    curl -LsSf https://astral.sh/uv/install.sh | sh
  See https://docs.astral.sh/uv/ for details.

FURTHER READING
  For the full agent-oriented workflow — kernel discovery internals,
  attach/exec/append recipes, ambiguity handling, and troubleshooting —
  read agents/lab.md in the sandbox source tree, or the copy shipped
  inside the sandbox at $SANDBOX_DIR/agents/lab.md.
HELP
}

require_uv() {
    if ! command -v uv >/dev/null 2>&1; then
        die "uv not found on PATH. Install it (no root needed) with one of:
  curl -LsSf https://astral.sh/uv/install.sh | sh
  brew install uv
See https://docs.astral.sh/uv/ for details, or run \`$PROG help\`."
    fi
}

sanitize_kernel_name() {
    # Lowercase; collapse runs of non-[a-z0-9._-] into '-'; trim leading/trailing '-'.
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
        | sed -e 's/[^a-z0-9._-]\+/-/g' -e 's/^-\+//' -e 's/-\+$//'
}

ensure_venv_with_ipykernel() {
    require_uv
    if [ ! -x "$VENV_DIR/bin/python" ]; then
        echo "$PROG: creating venv at $VENV_DIR" >&2
        uv venv "$VENV_DIR"
    fi
    local missing=()
    "$VENV_DIR/bin/python" -c "import ipykernel_launcher" 2>/dev/null || missing+=(ipykernel)
    "$VENV_DIR/bin/python" -c "import ipywidgets"        2>/dev/null || missing+=(ipywidgets)
    if [ ${#missing[@]} -gt 0 ]; then
        echo "$PROG: installing ${missing[*]} into $VENV_DIR" >&2
        uv pip install --python "$VENV_DIR/bin/python" "${missing[@]}"
    fi
}

ensure_runtime_deps() {
    # Ensure the venv also has the packages needed by the Python helper
    # (_lab_kernel.py): psutil, jupyter_client, nbformat.  ipykernel brings
    # in jupyter_client already; nbformat is a dep of jupyterlab.  Only
    # psutil is likely missing.
    ensure_venv_with_ipykernel
    local missing=()
    "$VENV_DIR/bin/python" -c "import psutil"        2>/dev/null || missing+=(psutil)
    "$VENV_DIR/bin/python" -c "import jupyter_client" 2>/dev/null || missing+=(jupyter_client)
    "$VENV_DIR/bin/python" -c "import nbformat"       2>/dev/null || missing+=(nbformat)
    if [ ${#missing[@]} -gt 0 ]; then
        echo "$PROG: installing ${missing[*]} into $VENV_DIR" >&2
        uv pip install --python "$VENV_DIR/bin/python" "${missing[@]}"
    fi
}

run_helper() {
    ensure_runtime_deps
    [ -f "$HELPER_PY" ] || die "cannot find helper at $HELPER_PY"
    exec "$VENV_DIR/bin/python" "$HELPER_PY" "$@"
}

cmd_kernel_add() {
    local raw_name="${1:-$(basename "$DIR")}"
    local name; name="$(sanitize_kernel_name "$raw_name")"
    [ -n "$name" ] || die "kernel add: empty name after sanitization"
    ensure_venv_with_ipykernel
    mkdir -p "$JUPYTER_CONFIG_DIR"
    "$VENV_DIR/bin/python" -m ipykernel install \
        --prefix "$JUPYTER_CONFIG_DIR" \
        --name "$name" \
        --display-name "$name (.venv)"
    echo "$PROG: registered kernel '$name' → $KERNELS_DIR/$name" >&2
}

cmd_kernel_list() {
    if [ ! -d "$KERNELS_DIR" ]; then
        echo "$PROG: no project-local kernels (no $KERNELS_DIR)" >&2
        return 0
    fi
    local found=0
    for k in "$KERNELS_DIR"/*/; do
        [ -d "$k" ] || continue
        found=1
        printf '  %s\n' "$(basename "$k")"
    done
    if [ "$found" -eq 0 ]; then
        echo "$PROG: no project-local kernels in $KERNELS_DIR" >&2
    fi
}

cmd_kernel_remove() {
    local raw_name="${1:?usage: lab kernel remove NAME}"
    local name; name="$(sanitize_kernel_name "$raw_name")"
    local target="$KERNELS_DIR/$name"
    [ -d "$target" ] || die "kernel remove: '$name' not found at $target"
    rm -rf "$target"
    echo "$PROG: removed kernel '$name'" >&2
}

cmd_kernel() {
    local sub="${1:-}"
    [ $# -gt 0 ] && shift
    case "$sub" in
        add)         cmd_kernel_add        "$@" ;;
        list|ls)     cmd_kernel_list       "$@" ;;
        remove|rm)   cmd_kernel_remove     "$@" ;;
        ps|find|exec|inspect)
            run_helper kernel "$sub" "$@" ;;
        ""|help|-h|--help)
            cat >&2 <<'KHELP'
Usage:
  lab kernel add [NAME]        Create ./.venv and register it as a kernelspec
  lab kernel list              List registered kernelspecs
  lab kernel remove NAME       Unregister a kernelspec
  lab kernel ps                List RUNNING kernels (PID, id, notebook)
  lab kernel find QUERY        Resolve a notebook path to its running kernel(s)
  lab kernel exec [-n NB|-k K] CODE   Execute code in a running kernel
  lab kernel inspect [-n NB|-k K]     Print live variables (%whos)
KHELP
            ;;
        *) die "kernel: unknown subcommand '$sub' (try '$PROG help')" ;;
    esac
}

cmd_notebook() {
    run_helper notebook "$@"
}

cmd_start() {
    require_uv
    mkdir -p "$JUPYTER_CONFIG_DIR" "$JUPYTER_DATA_DIR"

    # Refuse if already running.
    if [ -f "$BG_PID_FILE" ]; then
        local old_pid
        old_pid="$(cat "$BG_PID_FILE")"
        if kill -0 "$old_pid" 2>/dev/null; then
            echo "$PROG: lab already running (pid $old_pid).  Use 'lab stop' first." >&2
            return 1
        fi
        rm -f "$BG_PID_FILE"
    fi

    # Reuse the existing ensure_venv block that cmd_serve has.
    if [ -x "$VENV_DIR/bin/python" ]; then
        local missing=()
        "$VENV_DIR/bin/python" -c "import ipykernel_launcher" 2>/dev/null || missing+=(ipykernel)
        "$VENV_DIR/bin/python" -c "import ipywidgets"        2>/dev/null || missing+=(ipywidgets)
        if [ ${#missing[@]} -gt 0 ]; then
            echo "$PROG: installing ${missing[*]} into $VENV_DIR" >&2
            uv pip install --python "$VENV_DIR/bin/python" "${missing[@]}"
        fi
    fi

    local tls_args=()
    if [ -n "${JUPYTER_CERTFILE:-}" ] && [ -n "${JUPYTER_KEYFILE:-}" ]; then
        tls_args=(--certfile "$JUPYTER_CERTFILE" --keyfile "$JUPYTER_KEYFILE")
    fi

    nohup uvx --from jupyterlab \
        --with jupyterlmod \
        --with jupyterlab_notify \
        --with jupyterlab_execute_time \
        --with jupyter-resource-usage \
        --with jupyterlab-widgets \
        --with notebook-intelligence \
        jupyter-lab \
        --port "${PORT:-8888}" \
        --ip "${IP:-127.0.0.1}" \
        --no-browser \
        ${tls_args[@]+"${tls_args[@]}"} \
        "$@" \
        > "$BG_LOG_FILE" 2>&1 &
    local bg_pid=$!
    echo "$bg_pid" > "$BG_PID_FILE"
    echo "$PROG: started in background (pid $bg_pid)" >&2
    echo "$PROG: log at $BG_LOG_FILE" >&2

    # Wait briefly for the token URL to appear in the log, then print it.
    local attempt
    for attempt in $(seq 1 20); do
        if grep -q 'http' "$BG_LOG_FILE" 2>/dev/null; then
            grep 'http.*lab' "$BG_LOG_FILE" | tail -1 >&2 || true
            return 0
        fi
        sleep 0.25
    done
    echo "$PROG: server starting (check $BG_LOG_FILE for the URL)" >&2
    return 0
}

cmd_stop() {
    run_helper stop "$@"
    # Also clean up our pidfile.
    rm -f "$BG_PID_FILE" 2>/dev/null
}

cmd_status() {
    run_helper status "$@"
}

cmd_password() {
    require_uv
    mkdir -p "$JUPYTER_CONFIG_DIR"
    exec uvx --from jupyterlab jupyter-lab password "$@"
}

cmd_serve() {
    require_uv
    mkdir -p "$JUPYTER_CONFIG_DIR" "$JUPYTER_DATA_DIR"

    # Refresh kernel deps in an existing .venv so registered kernels keep
    # working after a venv rebuild. Skip silently if there's no .venv.
    if [ -x "$VENV_DIR/bin/python" ]; then
        local missing=()
        "$VENV_DIR/bin/python" -c "import ipykernel_launcher" 2>/dev/null || missing+=(ipykernel)
        "$VENV_DIR/bin/python" -c "import ipywidgets"        2>/dev/null || missing+=(ipywidgets)
        if [ ${#missing[@]} -gt 0 ]; then
            echo "$PROG: installing ${missing[*]} into $VENV_DIR" >&2
            uv pip install --python "$VENV_DIR/bin/python" "${missing[@]}"
        fi
    fi

    local tls_args=()
    if [ -n "${JUPYTER_CERTFILE:-}" ] && [ -n "${JUPYTER_KEYFILE:-}" ]; then
        tls_args=(--certfile "$JUPYTER_CERTFILE" --keyfile "$JUPYTER_KEYFILE")
    fi

    exec uvx --from jupyterlab \
        --with jupyterlmod \
        --with jupyterlab_notify \
        --with jupyterlab_execute_time \
        --with jupyter-resource-usage \
        --with jupyterlab-widgets \
        --with notebook-intelligence \
        jupyter-lab \
        --port "${PORT:-8888}" \
        --ip "${IP:-127.0.0.1}" \
        ${tls_args[@]+"${tls_args[@]}"} \
        "$@"
}

main() {
    case "${1:-}" in
        help|-h|--help)  usage ;;
        kernel)          shift; cmd_kernel   "$@" ;;
        notebook)        shift; cmd_notebook "$@" ;;
        start)           shift; cmd_start    "$@" ;;
        stop)            shift; cmd_stop     "$@" ;;
        status)          shift; cmd_status   "$@" ;;
        password)        shift; cmd_password "$@" ;;
        serve)           shift; cmd_serve    "$@" ;;
        "")              cmd_serve ;;
        -*)              cmd_serve "$@" ;;
        *)               die "unknown command '$1' (try '$PROG help')" ;;
    esac
}

main "$@"
